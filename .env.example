# Herrenlos Scanner — credential template
# ===========================================
# Copy this file to .env, set the values you need, then:  source .env
#
# Everything below is OPTIONAL.  Each variable unlocks one or more cantons.
# Without them, the scanner skips those cantons with a documented blocker.
# `python main.py ready` shows live status per canton.
#
# The web dashboard (docs/index.html) reads the SQLite DB only — it doesn't
# need any env vars.


# ─────────────────────────────────────────────────────────────────────────────
# FREE keys / accounts (no money required)
# ─────────────────────────────────────────────────────────────────────────────

# BS — Basel-Stadt. Free API key, ~5 min self-service registration.
#   Sign up at: https://api.geo.bs.ch/
# export BS_API_KEY=""

# BE — Bern. NO env vars needed.
#   First run opens your default browser → log in via AGOV/BE-Login.
#   macOS Safari → AppleScript extracts the token automatically.
#   Token cached at ~/.herrenlos_scanner/be_token.json — silent on later runs.

# VS — Valais. NO env vars needed.
#   First run opens a Playwright Chromium window → log in via SwissID.
#   Access + refresh tokens cached at ~/.herrenlos_scanner/vs_token.json.


# ─────────────────────────────────────────────────────────────────────────────
# PAID — Claude vision (Anthropic API) for hard image CAPTCHAs
# ─────────────────────────────────────────────────────────────────────────────
# Two cantons need this:
#   BL — handwritten CAPTCHA; local OCR scored 0% in our measurements.
#   GE — image CAPTCHA at scale; per scanner docstring "ddddocr struggles".
# Cost: ~$0.003 per parcel.  Full-canton BL ≈ $210, GE ≈ $200.
# Get a key at https://console.anthropic.com/
# export ANTHROPIC_API_KEY=""


# ─────────────────────────────────────────────────────────────────────────────
# PAID — residential proxies for IP-reputation-bound cantons
# ─────────────────────────────────────────────────────────────────────────────
# Each list is comma-separated  http://user:pass@host:port  URLs.
# One residential-proxy subscription works for all of them — point each var
# at the same gateway. Scanners rotate the IP every ~25 requests.
# Providers: smartproxy.com, oxylabs.io, brightdata.com (residential tier).
# Rough cost: ~$30–60 prepaid bandwidth covers a full GE, SO, or GR scan.

# GE — Imperva TSPD blocks datacenter IPs after ~30 requests
# export GE_PROXY_LIST=""

# SO — Google reCAPTCHA v3 scores datacenter IPs too low
#   (scanner: scanners/so_public.py — wired, awaiting proxies)
# export SO_PROXY_LIST=""

# Rate-limit-per-IP cantons (so low that even testing benefits from rotation)
# export GR_PROXY_LIST=""      # 10 req/day/IP — Switzerland's tightest cap
# export NE_PROXY_LIST=""      # ~50 req/day/IP + Altcha PoW CAPTCHA
# export SH_PROXY_LIST=""      # 100 req/day/IP — testing is fine, scaling needs rotation


# ─────────────────────────────────────────────────────────────────────────────
# CAN'T GET — documented dead-ends; env vars cannot unlock these
# ─────────────────────────────────────────────────────────────────────────────
# See test_fixtures.py:CANTON_STATUS for the verified blocker per canton.
#
#   AI, AR              — Terravis professional + mail-only for private persons
#   GL                  — my.gl.ch needs AGOV LoA-3 (federal e-ID launches 1 Dec 2026)
#   NW                  — online form is purpose-bound, postal return
#   OW                  — Terravis professional-only
#   TI                  — SIFTI requires registry-issued authorization (ORF Art. 28+)
#   VD                  — public path is form-based with 48h email turnaround
#   LU, TG, ZG, ZH      — SMS verification per query (operational dead-end)


# ─────────────────────────────────────────────────────────────────────────────
# Legacy: institutional geoportal.ch accounts
# ─────────────────────────────────────────────────────────────────────────────
# A handful of scanner files have a LEGACY professional code path targeting
# the geoportal.ch ktXX.owner.search endpoint. That endpoint requires an
# institutional account (notary / surveyor / bank / authority) that private
# persons cannot obtain. Listed for completeness — leave commented unless
# you actually hold institutional credentials.
#
# export AG_USERNAME=""   AG_PASSWORD=""
# export AI_USERNAME=""   AI_PASSWORD=""
# export AR_USERNAME=""   AR_PASSWORD=""
# export GL_USERNAME=""   GL_PASSWORD=""
# export NW_USERNAME=""   NW_PASSWORD=""
# export OW_USERNAME=""   OW_PASSWORD=""
# export SG_USERNAME=""   SG_PASSWORD=""
# export TG_USERNAME=""   TG_PASSWORD=""
# export TI_USERNAME=""   TI_PASSWORD=""
# export VD_USERNAME=""   VD_PASSWORD=""
