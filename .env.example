# Herrenlos Scanner — credential template
# Copy to .env, fill in values, then: source .env

# ── Shared geoportal.ch credentials (aGov account) ──────────────────────────
# One account covers AG, TG, SG, GL, NW, OW, TI, VD, AR, AI
# (canton-specific env vars below take priority if set)
export GEOPORTAL_USERNAME="your@email.ch"
export GEOPORTAL_PASSWORD="yourpassword"

# ── Canton-specific overrides (only needed if different from shared) ─────────
# export AG_USERNAME=""
# export AG_PASSWORD=""
# export TG_USERNAME=""
# export TG_PASSWORD=""
# export SG_USERNAME=""
# export SG_PASSWORD=""
# export GL_USERNAME=""
# export GL_PASSWORD=""
# export NW_USERNAME=""
# export NW_PASSWORD=""
# export OW_USERNAME=""
# export OW_PASSWORD=""
# export TI_USERNAME=""
# export TI_PASSWORD=""
# export VD_USERNAME=""
# export VD_PASSWORD=""
# export AR_USERNAME=""
# export AR_PASSWORD=""
# export AI_USERNAME=""
# export AI_PASSWORD=""

# ── BS (Basel-Stadt) ─────────────────────────────────────────────────────────
# Free API key from https://api.geo.bs.ch/
# export BS_API_KEY=""

# ── VS (Valais) — SwissID via Playwright ─────────────────────────────────────
# export VS_USERNAME=""   # not needed; browser login caches token automatically
# export VS_PASSWORD=""

# ── BE (Bern) — BE-Login (SwissID adapter, separate account required) ────────
# export BE_USERNAME=""
# export BE_PASSWORD=""
